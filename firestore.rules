rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isAuthenticated() { return request.auth != null; }
    function isOwner(userId) { return isAuthenticated() && request.auth.uid == userId; }
    
    // Core isAdmin check - whitelisting critical admins first to prevent lockout
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.uid == "E30ao1D3wdPgDLPYX556x41PDr93" ||
        ("email" in request.auth.token && request.auth.token.email == "jhecksanto@gmail.com") ||
        ("email" in request.auth.token && request.auth.token.email == "admin@vitta.club") ||
        ("email" in request.auth.token && request.auth.token.email == "suporte@vitta.club") ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin")
      );
    }
    
    // Support for 2FA and admin actions
    function isVerified() { return isAuthenticated() && request.auth.token.email_verified == true; }
    function isAdminFull() { return isAdmin(); } // Simplified to prevent confusion

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Validation Helpers with "Ghost Field" protection (Pillar 2 & 5)
    function hasOnly(fields) {
      return incoming().keys().hasOnly(fields);
    }

    // --- Collections ---

    match /users/{userId} {
      // Users can read/write their own profile, admins can do anything
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated(); // Allow creation during signup
      allow update: if isOwner(userId) || isAdmin();
      allow list: if isAdmin(); // Only admins can list all users
    }

    match /appointments/{appointmentId} {
      allow get: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || 
        (resource.data.professionalUserId == request.auth.uid) ||
        (resource.data.professionalId != null && 
         resource.data.professionalId is string && 
         resource.data.professionalId != "" && 
         exists(/databases/$(database)/documents/professionals/$(resource.data.professionalId)) && 
         get(/databases/$(database)/documents/professionals/$(resource.data.professionalId)).data.userId == request.auth.uid) ||
        isAdmin()
      );
      allow list: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || 
        (resource.data.professionalUserId == request.auth.uid) ||
        (resource.data.professionalId != null && resource.data.professionalId != "") ||
        isAdmin()
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || 
        (resource.data.professionalUserId == request.auth.uid) ||
        (resource.data.professionalId != null && 
         resource.data.professionalId is string && 
         resource.data.professionalId != "" && 
         exists(/databases/$(database)/documents/professionals/$(resource.data.professionalId)) && 
         get(/databases/$(database)/documents/professionals/$(resource.data.professionalId)).data.userId == request.auth.uid) ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    match /professionals/{professionalId} {
      allow read: if true; // Public list
      allow create: if isAdmin();
      allow delete: if isAdmin();
      allow update: if isAdmin() || (
        isAuthenticated() && (
          request.auth.token.email == resource.data.email ||
          (resource.data.userId == request.auth.uid)
        )
      );
    }

    match /partners/{partnerId} {
      allow read: if true; // Public list
      allow write: if isAdmin();
    }
    
    match /categories/{categoryId} {
      allow read: if true; // Public list
      allow create: if isAdmin() || (isAuthenticated() && incoming().type == "liberal");
      allow update, delete: if isAdmin() || (isAuthenticated() && resource.data.type == "liberal");
    }
    
    match /liberal_professionals/{id} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin() || (isAuthenticated() && (resource.data.userId == request.auth.uid || request.auth.uid != null));
    }
    
    match /exams/{examId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /user_exams/{examId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }
    
    match /offers/{offerId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /vouchers/{voucherId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && incoming().userId == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /vouchers_catalog/{voucherId} {
      allow read: if true;
      allow create: if isAuthenticated() && incoming().sellerId == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.sellerId == request.auth.uid || isAdmin());
      allow delete: if isAuthenticated() && (resource.data.sellerId == request.auth.uid || isAdmin());
    }
    
    match /user_vouchers/{voucherId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && incoming().userId == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }
    
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated(); // Support system notifications
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }
    
    match /health_metrics/{metricId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isAuthenticated() && (incoming().userId == request.auth.uid || isAdmin());
    }

    match /medications/{medicationId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isAuthenticated() && (incoming().userId == request.auth.uid || isAdmin());
    }

    match /health_goals/{goalId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isAuthenticated() && (incoming().userId == request.auth.uid || isAdmin());
    }
    
    match /verification_codes/{codeId} {
      // Allow unauthenticated access for server-side code storage (using Client SDK on server)
      allow read, write: if true;
    }
    
    match /system_configs/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /chats/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
      
      match /messages/{messageId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId) || isAdmin();
      }
    }
    
    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated(); // Allow logging from anywhere
    }
    
    match /transactions/{txId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated();
      allow update: if isAdmin();
    }

    match /withdrawals/{withdrawalId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && incoming().userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    match /pharmacies/{pharmacyId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /subscription_plans/{planId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /user_subscriptions/{subId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated() && incoming().userId == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    match /faqs/{faqId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /economies/{economyId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && incoming().userId == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }
  }
}
